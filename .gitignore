# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem
*.key

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Editors
.vscode/
.idea/

# Secrets / credentials
service-account*.json
credentials*.json
client_secret*.json

# Backups
*.bak
*.hm-backup.*

# Claude Code harness state (per-machine, not committed)
.claude/.git-harness-checked
.claude/worktrees/
.claude/sessions/
.claude/settings.local.json
